# ─── Database ────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/product_community_db
DB_USERNAME=root
DB_PASSWORD=yourpassword
DB_ROOT_PASSWORD=yourrootpassword

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-base64-encoded-secret-minimum-32-characters
JWT_EXPIRATION=86400000

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ─── Backend Server ───────────────────────────────────────────
SERVER_PORT=8081
